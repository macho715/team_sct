+    else if(e.key==='Enter'){if(idx>=0&&items[idx]){e.preventDefault();items[idx].click();}idx=-1;return;}
+    else return;
+    items.forEach((it,i)=>{it.setAttribute('role','option');it.classList.toggle('active',i===idx);if(i===idx)it.scrollIntoView({block:'nearest'});});
+  });
+  sr.setAttribute('role','listbox');
