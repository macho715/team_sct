+// ---- a11y: search results keyboard navigation (arrow/Enter) ----
+(function(){let idx=-1;
+  sb.addEventListener('input',()=>{idx=-1;});
+  sb.addEventListener('keydown',e=>{
+    const items=[].slice.call(sr.querySelectorAll('.si'));
