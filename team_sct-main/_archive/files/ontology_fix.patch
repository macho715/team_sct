+// Spotlight: when members are selected, keep only them + their 1-hop neighbours bright.
+function applyMemberFocus(){
+  if(memberSel.size===0){
+    visNodes.update(DATA.nodes.map(n=>({id:n.id,opacity:1})));
+    if(bridgeMode) applyBridge();
+    return;
+  }
+  const keep=new Set();
+  memberSel.forEach(mid=>{keep.add(mid);(adj[mid]||[]).forEach(x=>keep.add(x.id));});
+  visNodes.update(DATA.nodes.map(n=>({id:n.id,opacity:keep.has(n.id)?1:0.1})));
+  // focus the most-connected selected member
+  const focusId=[...memberSel].sort((a,b)=>(byId[b].deg||0)-(byId[a].deg||0))[0];
+  if(focusId) network.focus(focusId,{scale:0.9,animation:!reduceMotion});
+}
+function applyBridge(){
+  visNodes.update(DATA.nodes.map(n=>{
+    const dim=bridgeMode&&n.bridges<2;
+    return {id:n.id,opacity:dim?0.18:1,
+      borderWidth:bridgeMode&&n.bridges>=3?3:1,
+      color:{background:nodeColor(n),border:bridgeMode&&n.bridges>=3?'#f2c14e':'#0c0c16',highlight:{background:nodeColor(n),border:'#fff'}}};
+  }));
+}
