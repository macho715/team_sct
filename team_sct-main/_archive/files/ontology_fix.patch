+// ---- deep-link + localStorage view state ----
+const LS_KEY='graphify_pro_view';
+function syncState(){
+  const p=new URLSearchParams();
+  if(colorMode==='community')p.set('c','1');
+  if(!showInferred)p.set('i','0');
+  if(bridgeMode)p.set('b','1');
+  if(memberSel.size)p.set('m',[...memberSel].join(','));
+  const h=p.toString();
+  try{history.replaceState(null,'',h?('#'+h):location.pathname+location.search);}catch(e){}
+  try{localStorage.setItem(LS_KEY,h);}catch(e){}
+}
+function restoreState(){
+  let h=location.hash.replace(/^#/,'');
+  if(!h){try{h=localStorage.getItem(LS_KEY)||'';}catch(e){}}
+  if(!h)return;
+  const p=new URLSearchParams(h);
+  const m=p.get('m');
+  if(m){m.split(',').forEach(id=>{const c=memberChips[id];if(c&&!memberSel.has(id)){memberSel.add(id);c.classList.add('on');}});applyMemberFocus();}
+  if(p.get('c')==='1')$('t-color').click();
+  if(p.get('i')==='0')$('t-inf').click();
+  if(p.get('b')==='1')$('t-bridge').click();
+  syncState();
