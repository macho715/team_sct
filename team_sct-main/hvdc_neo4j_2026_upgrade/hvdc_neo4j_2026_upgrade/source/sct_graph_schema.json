{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://samsungcnt-hvdc.example/schema/sct-graph-data.schema.json",
  "title": "SCT AI-Ready Graph Data Schema",
  "type": "object",
  "required": [
    "metadata",
    "nodes",
    "edges"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "graph_id",
        "schema_version",
        "generated_at",
        "validation_summary"
      ]
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "node_type",
          "status",
          "evidence",
          "business_rule",
          "last_updated",
          "next_action"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "node_type": {
            "type": "string",
            "enum": [
              "Person",
              "ActorRole",
              "ShipmentUnit",
              "RoutingPattern",
              "JourneyStage",
              "JourneyLeg",
              "MilestoneEvent",
              "Document",
              "BOEDocument",
              "DeliveryOrderDocument",
              "BillOfLadingDocument",
              "PackingListDocument",
              "CommercialInvoiceDocument",
              "CustomsEntry",
              "ReleaseOrder",
              "WarehouseHandlingProfile",
              "WarehouseTask",
              "OffshoreStagingNode",
              "MarineOperation",
              "LCTOperation",
              "SiteReceipt",
              "InspectionEvent",
              "CostGuardResult",
              "Invoice",
              "InvoiceLine",
              "ChargeComponent",
              "RateRef",
              "TariffRef",
              "CostPolicy",
              "CommunicationEvent",
              "ApprovalAction",
              "AuditRecord",
              "KPIObservation",
              "OperationDataset",
              "ReportArtifact",
              "LocationNode",
              "Port",
              "Site",
              "Standard",
              "RegulatoryRequirement",
              "BusinessRule",
              "EvidenceAssertion",
              "ResourceRole",
              "Concept"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "AMBER",
              "FAIL",
              "ZERO"
            ]
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "business_rule": {
            "type": "string",
            "minLength": 1
          },
          "last_updated": {
            "type": "string",
            "format": "date-time"
          },
          "next_action": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "edge_type",
          "status",
          "evidence",
          "business_rule",
          "last_updated",
          "next_action"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "edge_type": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "AMBER",
              "FAIL",
              "ZERO"
            ]
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "business_rule": {
            "type": "string",
            "minLength": 1
          },
          "last_updated": {
            "type": "string",
            "format": "date-time"
          },
          "next_action": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}